{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://craft.do/schemas/design-theme.schema.json",
  "title": "Craft Design Theme",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string" },
    "description": { "type": "string" },
    "author": { "type": "string" },
    "license": { "type": "string" },
    "source": { "type": "string" },
    "mode": {
      "type": "string",
      "enum": ["solid", "scenic"]
    },
    "backgroundImage": { "type": "string" },
    "background": { "type": "string" },
    "foreground": { "type": "string" },
    "accent": { "type": "string" },
    "info": { "type": "string" },
    "success": { "type": "string" },
    "destructive": { "type": "string" },
    "paper": { "type": "string" },
    "navigator": { "type": "string" },
    "input": { "type": "string" },
    "popover": { "type": "string" },
    "popoverSolid": { "type": "string" },
    "supportedModes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["light", "dark"]
      }
    },
    "shikiTheme": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "light": { "type": "string" },
        "dark": { "type": "string" }
      }
    },
    "dark": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "background": { "type": "string" },
        "foreground": { "type": "string" },
        "accent": { "type": "string" },
        "info": { "type": "string" },
        "success": { "type": "string" },
        "destructive": { "type": "string" },
        "paper": { "type": "string" },
        "navigator": { "type": "string" },
        "input": { "type": "string" },
        "popover": { "type": "string" },
        "popoverSolid": { "type": "string" }
      }
    }
  }
}

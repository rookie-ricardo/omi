  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^39.8.3",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "typescript": "5.8.3",
    "vite": "^6.2.2",
    "vitest": "^3.1.1"

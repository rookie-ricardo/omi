{
  "name": "omi-agent-workbench",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm --filter @omi/desktop dev",
    "format": "biome check . --write",
    "ws15:gate": "tsx scripts/ws15-gate.ts",
    "ws15:matrix": "tsx scripts/ws15-gate.ts --matrix-only",
    "lint": "biome check .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.14.1",
    "tsx": "^4.19.3",
    "turbo": "^2.8.17",
    "typescript": "5.8.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM"],
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@omi/agent": ["packages/agent/src/index.ts"],
      "@omi/core": ["packages/core/src/index.ts"],
      "@omi/provider": ["packages/provider/src/index.ts"],
      "@omi/tools": ["packages/tools/src/index.ts"],
      "@omi/store": ["packages/store/src/index.ts"],
      "@omi/memory": ["packages/memory/src/index.ts"],
      "@omi/settings": ["packages/settings/src/index.ts"],
      "@omi/prompt": ["packages/prompt/src/index.ts"]
    }
  }
}
